# Copy this file to .env and fill in your provider settings.
# Do not commit .env.

AI_IME_PROVIDER=openai-compatible
AI_IME_PROVIDER_PRESET=openai
AI_IME_OPENAI_BASE_URL=https://api.openai.com/v1
AI_IME_OPENAI_API_KEY=replace-with-your-key
AI_IME_OPENAI_MODEL=gpt-5.4-mini

# Ollama example:
# AI_IME_PROVIDER=ollama
# AI_IME_OLLAMA_BASE_URL=http://localhost:11434
# AI_IME_OLLAMA_MODEL=qwen2.5:7b

# Privacy defaults:
AI_IME_AUTO_LEARN=true
AI_IME_AUTO_ANALYZE_WITH_AI=false
AI_IME_AUTO_DEPLOY_RIME=true
